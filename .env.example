VALKEY_URL=redis://valkey:6379
SESSION_TTL_SECONDS=3600
PROXY_TIMEOUT_MS=30000
ALLOWED_CLIENT_IPS=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
TRUST_PROXY_HEADERS=false
SESSION_HEADER=X-Session-ID
PROXY_PORT=8080
ADMIN_PORT=3001

# Optional TLS for proxy and admin listeners (both Node and Go).
# When both files exist and are readable, servers listen with HTTPS.
TLS_CERT_FILE=/certs/tls.crt
TLS_KEY_FILE=/certs/tls.key
