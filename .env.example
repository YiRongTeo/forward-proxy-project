# Example configuration files live in config/
#
#   config/node-proxy.json   Node.js proxy (ports 8080 / 3001)
#   config/go-proxy.json     Go proxy (ports 8081 / 9001)
#
# Docker Compose mounts these to /config/config.json inside each container.
#
# Local run:
#   node node-proxy/src/index.js --config config/node-proxy.json
#   go-proxy/cmd/proxy -config config/go-proxy.json
#
# TLS is enabled when tls.certFile and tls.keyFile point to readable files.
# Leave them empty or omit cert files to use plain HTTP.
