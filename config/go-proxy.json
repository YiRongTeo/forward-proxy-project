{
  "valkeyUrl": "redis://valkey:6379",
  "valkeyTls": {
    "enabled": false,
    "caFile": "",
    "certFile": "",
    "keyFile": "",
    "serverName": "",
    "insecureSkipVerify": false
  },
  "proxyPort": 8081,
  "adminPort": 9001,
  "proxyTimeoutMs": 30000,
  "allowedClientIps": [
    "127.0.0.1",
    "::1",
    "172.16.0.0/12",
    "172.17.0.0/16",
    "172.18.0.0/16",
    "172.19.0.0/16",
    "172.20.0.0/16",
    "172.21.0.0/16",
    "172.22.0.0/16",
    "172.23.0.0/16",
    "172.24.0.0/16",
    "172.25.0.0/16",
    "10.0.0.0/8",
    "192.168.0.0/16"
  ],
  "trustProxyHeaders": false,
  "sessionHeader": "X-Session-ID",
  "defaultAllowedDomains": [],
  "tls": {
    "certFile": "/certs/tls.crt",
    "keyFile": "/certs/tls.key"
  }
}
