{
  "manifest_version": 3,
  "name": "Forward Proxy Session",
  "version": "1.1.0",
  "description": "Routes Chrome through the forward proxy and sends the session ID via X-Session-ID and proxy authentication.",
  "permissions": [
    "proxy",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Forward Proxy Session"
  },
  "options_page": "options.html"
}
